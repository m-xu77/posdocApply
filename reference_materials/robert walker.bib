@article{WOS:000259754600004,
  type = {Article},
  title = {Measuring Poverty in {{Britain}} as a Multi-Dimensional Concept, 1991 to 2003},
  author = {Tomlinson, Mark and Walker, Robert and Williams, Glenn},
