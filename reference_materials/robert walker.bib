@article{WOS:000461826600017,
  type = {Article},
  title = {Getting by in New York City: {{Bonding}}, Bridging and Linking Capital in Poverty-Impacted Neighborhoods},
  author = {Lukasiewicz, Karolina and Bahar, Ozge Sensoy and Ali, Samira and Gopalan, Priya and Parker, Gary and Hawkins, Robert and McKay, Mary and Walker, Robert},
  date = {2019-03},
  journaltitle = {CITY \& COMMUNITY},
  volume = {18},
  number = {1},
  pages = {280--301},
  publisher = {SAGE PUBLICATIONS INC},
  location = {2455 TELLER RD, THOUSAND OAKS, CA 91320 USA},
  issn = {1535-6841},
  doi = {10.1111/cico.12373},
  abstract = {A lack or low level of social capital is associated with negative outcomes for communities impacted by poverty. However, less is known about how different types of social capital operate on the ground in poverty-impacted urban neighborhoods. This article explores the ways in which bonding, bridging, and linking capital manifest among residents of two poverty-impacted neighborhoods in New York City. Findings of the study reveal that urban neighborhood characteristics, more than individual-level factors, compromise the ability to develop and utilize the leveraging role of bridging and linking capital. Lack of safety resulted in limited trust, and involvement in community life limit bonding capital. Opportunities for bridging are restricted by the socioeconomically homogenous and spatially segregated nature of the communities. Linking capital is undermined by the lack of resources in the neighborhoods. These structural barriers prevent communities from breaking the cycle of poverty and should be explicitly targeted when developing interventions focused on building social capital.},
  affiliation = {Lukasiewicz, K (Corresponding Author), NYU, Silver Sch Social Work, McSilver Inst Poverty Policy \& Res, 20 Cooper Sq,Second Floor, New York, NY 10003 USA. Lukasiewicz, Karolina; Gopalan, Priya; Hawkins, Robert, NYU, New York, NY USA. Bahar, Ozge Sensoy; Parker, Gary; McKay, Mary, Washington Univ, St Louis, MO USA. Ali, Samira, Univ Houston, Houston, TX 77004 USA. Walker, Robert, Univ Oxford, Oxford, England.},
