@article{WOS:001321226800001,
  type = {Article},
  title = {Understanding Poverty Alleviation in Rural China: {{The}} Role of Policy Brokers},
  author = {Li, Mianguan and Yang, Zaiping and Walker, Robert},
  date = {2025-09},
  journaltitle = {SOCIAL POLICY \& ADMINISTRATION},
  volume = {59},
  number = {5},
  pages = {779--789},
  publisher = {WILEY},
  location = {111 RIVER ST, HOBOKEN 07030-5774, NJ USA},
  issn = {0144-5596},
  doi = {10.1111/spol.13087},
  abstract = {China eradicated rural extreme poverty in 2020 after an 8-year campaign that combined endogenous economic development involving local people with social assistance. Ethnographic research in a village in southwest China reports township officials, under-resourced and pressed by higher tiers of government to meet the poverty-eradication target, commissioning an entrepreneur as a policy-broker. The latter established enterprises nominally to provide local employment, while seeking profitability from their investment. Prioritising poverty eradication over sustainability, government subsidies were employed to engineer income transfers lifting villagers out of poverty by the target date. Thereafter, transfers of income from the enterprises to impoverished people were at best irregular. The experience highlights the distorting effect of policy targets and the limits to endogenous development undertaken under time-pressure with villagers neither consulted nor benefiting from new employment.},
  affiliation = {Walker, R (Corresponding Author), Beijing Normal Univ, Jingshi Acad, Beijing, Peoples R China. Li, Mianguan; Yang, Zaiping, Sun Yat Sen Univ, Ctr Chinese Publ Adm Res, Guangzhou, Guangdong, Peoples R China. Li, Mianguan; Yang, Zaiping, Sun Yat Sen Univ, Sch Govt, Guangzhou, Guangdong, Peoples R China. Walker, Robert, Beijing Normal Univ, Jingshi Acad, Beijing, Peoples R China.},
