@article{WOS:000684450500001,
  type = {Article},
  title = {Village Governance, Social Cohesion and Contentment with Social Assistance in {{Northern China}}},
  author = {Yang, Lichao and Walker, Robert},
  date = {2023-05-04},
  journaltitle = {JOURNAL OF ASIAN PUBLIC POLICY},
  volume = {16},
  number = {2},
